// Run `prisma generate` after changing models.
// Run `prisma migrate dev` to apply schema changes to the database.
// To switch database engine, change the provider value and update DATABASE_URL in .env.
// Development: docker compose --profile development exec api-dev npx prisma migrate dev --name <migration_name>
// Production: docker compose --profile production exec api npx prisma migrate deploy


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TelegramSession {
  id                    BigInt               @id @default(autoincrement())
  session_id            String               @db.Text
  telegram_user_id      String               @db.VarChar(255)
  telegram_username     String               @db.VarChar(255)
  telegram_access_hash  String               @db.VarChar(255)
  server_name           String               @db.VarChar(255)
  callback_url          String               @db.Text
  status                String               @db.VarChar(50)
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt
  messages              Message[]
  tenantMessageStates   TenantMessageState[]

  @@map("telegram_sessions")
}

// ── Message Pipeline ────────────────────────────────────────────────

enum MessageStatus {
  downloaded
  forwarded
  delivery_failed
}

model Message {
  id                       BigInt        @id @default(autoincrement())
  session_id               BigInt
  raw_payload              String?       @db.Text
  status                   MessageStatus @default(downloaded)
  delivery_retry_count     Int           @default(0)
  next_delivery_attempt_at DateTime?
  delivery_failed_at       DateTime?
  last_delivery_error      String?       @db.Text
  created_at               DateTime      @default(now())
  updated_at               DateTime      @updatedAt
  session                  TelegramSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id, id, status])
  @@map("messages")
}

model TenantMessageState {
  id                BigInt   @id @default(autoincrement())
  session_id        BigInt   @unique
  last_forwarded_id BigInt   @default(0)
  updated_at        DateTime @updatedAt
  session           TelegramSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@map("tenant_message_state")
}

// ── Media File Tracking ─────────────────────────────────────────────

model MediaFile {
  id         BigInt   @id @default(autoincrement())
  file_key   String   @unique @db.VarChar(255)
  file_path  String   @db.Text
  file_url   String   @db.Text
  expires_at DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([expires_at])
  @@map("media_files")
}
