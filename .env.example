PORT=3000
SERVER_NAME=server-1 # Must be unique for each server
APPLICATION_API_KEY= # This is used to authenticate requests ServerRoute

SSL_CERT_DIR= # Path to dir containing certificate.pem + private.key (mounted into nginx at /etc/nginx/ssl)

TELEGRAM_API_ID= # from https://my.telegram.org
TELEGRAM_API_HASH= # from https://my.telegram.org

DATABASE_URL=postgresql://your_db_user:your_db_password@db:5432/telegram_api

# How often (in seconds) the session watchdog checks pool health
WATCHDOG_INTERVAL_SECONDS=10

# ── Message Pipeline ──────────────────────────────────────────────────
FORWARDING_INTERVAL_MS=1000

# Base delay (in seconds) for callback delivery retries.
# Delay grows linearly: attempt 1 = 1*base, attempt 2 = 2*base, etc.
CALLBACK_RETRY_BASE_DELAY_SECONDS=5

# Maximum number of delivery retries before marking a message as permanently failed
CALLBACK_MAX_RETRIES=5

# ── S3 Storage ──────────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT= # Custom endpoint for MinIO / self-hosted S3-compatible storage (e.g. http://localhost:9000)
S3_PUBLIC_URL= # Public base URL that maps to the bucket root (e.g. custom domain / CDN like https://chat-x.asset.example.com). When set, URLs are {S3_PUBLIC_URL}/{key}; leave empty for the default https://{bucket}.s3.{region}.amazonaws.com/{key}
S3_FOLDER_PATH=telegram-media # Folder/prefix inside the S3 bucket
