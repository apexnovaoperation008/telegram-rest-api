PORT=3000
SERVER_NAME=server-1 # Must be unique for each server
APPLICATION_API_KEY= # This is used to authenticate requests ServerRoute

TELEGRAM_API_ID= # from https://my.telegram.org
TELEGRAM_API_HASH= # from https://my.telegram.org

# Remember to change the database provider in prisma/schema.prisma
DATABASE_URL=postgresql://your_db_user:your_db_password@db:5432/telegram_api

REDIS_URL=redis://redis:6379

# How often (in seconds) the session watchdog checks pool health
WATCHDOG_INTERVAL_SECONDS=10

# How often (in seconds) the queue job watchdog polls for pending jobs
QUEUE_JOB_INTERVAL_SECONDS=30

# ── Message Pipeline ──────────────────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=5
DOWNLOAD_TIMEOUT_SECONDS=600
MAX_DOWNLOAD_RETRIES=3
ALBUM_BUFFER_MS=300
FORWARDING_INTERVAL_MS=1000
