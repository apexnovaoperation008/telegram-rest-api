{
	"name": "telegram-api-server",
	"version": "1.0.0",
	"description": "Telegram API Server built with Fastify and TypeScript",
	"main": "dist/server.js",
	"scripts": {
		"build": "tsc",
		"start": "node dist/server.js",
		"dev": "ts-node-dev --respawn --transpile-only src/server.ts",
		"test": "vitest run",
		"drizzle:generate": "drizzle-kit generate",
		"drizzle:migrate": "drizzle-kit migrate",
		"migrate": "node dist/migrate.js",
		"drizzle:push": "drizzle-kit push",
		"drizzle:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1041.0",
		"dotenv": "^16.4.7",
		"drizzle-orm": "^0.44.0",
		"fastify": "^5.2.1",
		"file-type": "^16.5.4",
		"pg": "^8.13.0",
		"telegram": "^2.26.22"
	},
	"devDependencies": {
		"@types/node": "^22.13.9",
		"@types/pg": "^8.11.0",
		"drizzle-kit": "^0.31.0",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.8.2",
		"vitest": "^4.1.5"
	}
}
